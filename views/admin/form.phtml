                <?php endif; ?>
            </div>

            <div class="sidebar-card">
                <div class="form-group checkboxes-group">
                    <label>Skills associés</label>
                    <div class="checkboxes-list">
                        <?php
                        // check boxes pour les skills
                        foreach ($skills as $skill): ?>
                            <label class="checkbox-label">
                                <input type="checkbox" name="skills[]" value="<?= (int) $skill->getId() ?>"
                                    <?= in_array($skill->getId(), $projectSkills) ? 'checked' : '' ?>>
                                <?= htmlspecialchars($skill->getName()) ?>
                            </label>
                        <?php endforeach; ?>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Quill Editor resources -->
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script>
    // init quill
    let quill = new Quill('#editor-container', {
        theme: 'snow'
    });

    // sync quill content dans le textarea hidden avant submit
    document.querySelector('.admin-form').onsubmit = function () {
        document.querySelector('#editor-textarea').value = quill.root.innerHTML;
    };
</script>