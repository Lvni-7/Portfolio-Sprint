<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars($title ?? 'Mon Portfolio') ?></title>
    <!-- load google fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
